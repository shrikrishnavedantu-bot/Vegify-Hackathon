{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "image": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "bmrData": {
          "type": "object",
          "properties": {
            "age": { "type": "number" },
            "gender": { "type": "string", "enum": ["male", "female", "other"] },
            "weight": { "type": "number" },
            "height": { "type": "number" },
            "activityLevel": { "type": "string" },
            "bmr": { "type": "number" },
            "maintenanceCalories": { "type": "number" }
          }
        },
        "totalSnaps": { "type": "number" },
        "totalSwaps": { "type": "number" }
      },
      "required": ["id", "name", "email", "createdAt"]
    },
    "Swap": {
      "title": "Swap",
      "description": "A plant-based food swap",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "originalDish": { "type": "string" },
        "originalImage": { "type": "string", "format": "uri" },
        "veganImage": { "type": "string", "format": "uri" },
        "swapText": { "type": "string" },
        "flavorPromise": { "type": "string" },
        "savedDate": { "type": "string", "format": "date-time" },
        "nutritionSaved": {
          "type": "object",
          "properties": {
            "saturatedFatReduced": { "type": "number" },
            "fiberAdded": { "type": "number" },
            "caloriesSaved": { "type": "number" }
          }
        }
      },
      "required": ["id", "userId", "originalDish", "savedDate"]
    },
    "CalorieLog": {
      "title": "CalorieLog",
      "description": "Daily calorie tracking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "meals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "mealType": { "type": "string" },
              "foodName": { "type": "string" },
              "calories": { "type": "number" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "totalCalories": { "type": "number" }
      },
      "required": ["id", "userId", "date", "totalCalories"]
    },
    "CommunityPost": {
      "title": "CommunityPost",
      "description": "A post in the community feed",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string", "format": "uri" },
        "category": { "type": "string", "enum": ["Success Story", "Question", "Recipe Sharing", "Transformation", "General"] },
        "content": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "likes": { "type": "number" },
        "likedBy": { "type": "array", "items": { "type": "string" } },
        "comments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "userName": { "type": "string" },
              "content": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "userName", "category", "content", "createdAt"]
    },
    "Recipe": {
      "title": "Recipe",
      "description": "A plant-based recipe",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "swap": { "type": "string" },
        "prepTime": { "type": "string" },
        "cookTime": { "type": "string" },
        "servings": { "type": "number" },
        "difficulty": { "type": "string" },
        "ingredients": { "type": "array", "items": { "type": "string" } },
        "instructions": { "type": "array", "items": { "type": "string" } },
        "videoUrl": { "type": "string", "format": "uri" },
        "nutrition": { "type": "object" }
      },
      "required": ["id", "title", "category", "ingredients", "instructions"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/swaps/{swapId}": {
      "schema": "Swap",
      "description": "Saved food swaps"
    },
    "/calorieLogs/{logId}": {
      "schema": "CalorieLog",
      "description": "Daily calorie logs"
    },
    "/communityPosts/{postId}": {
      "schema": "CommunityPost",
      "description": "Community feed posts"
    },
    "/recipes/{recipeId}": {
      "schema": "Recipe",
      "description": "Pre-seeded recipes"
    }
  }
}
